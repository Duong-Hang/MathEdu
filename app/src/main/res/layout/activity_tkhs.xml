<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/img_7"
    tools:context=".PH.TKHs">

    <ImageButton
        android:id="@+id/imgbtnql"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@null"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/img_9" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="358dp"
        android:layout_height="154dp"
        android:layout_gravity="center"
        app:srcCompat="@drawable/img_2" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_gravity="center"
        app:cardBackgroundColor="#84EEFF"
        app:cardCornerRadius="30dp"
        app:strokeColor="@color/mauvien"
        app:strokeWidth="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Title -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TẠO TÀI KHOẢN"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#004875"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Username -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Họ tên"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edthoten"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập họ tên"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:layout_marginBottom="8dp"
                android:textSize="12dp" />


            <!-- Password -->

            <TextView
                android:id="@+id/textView4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mật khẩu"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtpassword"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />

            <!-- Lop -->

            <TextView
                android:id="@+id/textView5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lớp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />


            <!-- Button -->

            <Spinner
                android:id="@+id/spinner"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext" />

            <Button
                android:id="@+id/btntao"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/button_login"
                android:backgroundTint="@null"
                android:text="Đăng ký"
                android:textColor="#000"
                android:textSize="18sp"
                android:textStyle="bold" />


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>