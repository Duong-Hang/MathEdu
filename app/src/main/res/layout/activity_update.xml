<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_7"
    android:orientation="vertical"
    tools:context=".PH.Update">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageButton
            android:id="@+id/btnql"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/img_9" />


        <ImageView
            android:id="@+id/imgavatar"
            android:layout_width="match_parent"
            android:layout_height="159dp"
            app:srcCompat="@drawable/img_8" />

        <Button
            android:id="@+id/btnavatar"
            android:layout_width="160dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_margin="10dp"
            android:text="Thay đổi avatar"
            android:textSize="14sp" />

        <!--thay doi avatar-->
        <androidx.cardview.widget.CardView
            android:id="@+id/Cardavatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@android:color/transparent"
            android:visibility="gone">

            <!--dong 1-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/avatar1"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar1" />

                    <ImageButton
                        android:id="@+id/avatar2"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/avatar3"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar3" />

                    <ImageButton
                        android:id="@+id/avatar4"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar4" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageButton
                        android:id="@+id/avatar5"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar5" />

                    <ImageButton
                        android:id="@+id/avatar6"
                        android:layout_width="0dp"
                        android:layout_height="159dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:scaleType="fitCenter"
                        app:srcCompat="@drawable/avatar6" />
                </LinearLayout>
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/Cardtt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            app:cardBackgroundColor="#84EEFF"
            app:cardCornerRadius="30dp"
            app:strokeColor="@color/mauvien"
            app:strokeWidth="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:background="@drawable/bg_rounded"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="15dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="CẬP NHẬT THÔNG TIN"
                    android:textAlignment="center"
                    android:textColor="#004875"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Mk -->
                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Họ tên"
                    android:textAlignment="center"
                    android:textColor="#005CA0"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtname"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_edittext"
                    android:padding="5dp"
                    android:textColorHint="#3867B3"
                    android:textSize="12dp" />

                <!-- Password -->

                <TextView
                    android:id="@+id/textView4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Email"
                    android:textAlignment="center"
                    android:textColor="#005CA0"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/edtemail"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_edittext"
                    android:padding="5dp"
                    android:textColorHint="#3867B3"
                    android:textSize="12dp" />

                <!-- Button -->
                <Button
                    android:id="@+id/btnxn"
                    android:layout_width="180dp"
                    android:layout_height="60dp"
                    android:background="@drawable/button_login"
                    android:backgroundTint="@null"
                    android:text="Xác nhận"
                    android:textColor="#FFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>