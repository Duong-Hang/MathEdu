<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/Dangky"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/maunen"
    android:orientation="vertical"
    tools:context=".Login.form_dang_ky">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="154dp"
        app:srcCompat="@drawable/img_2" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_gravity="center"
        app:cardBackgroundColor="#84EEFF"
        app:cardCornerRadius="30dp"
        app:strokeColor="@color/mauvien"
        app:strokeWidth="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Title -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ĐĂNG KÝ"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#004875"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Username -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tên đăng nhập"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edthoten"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập tên đăng nhập"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:layout_marginBottom="8dp"
                android:textSize="12dp" />

            <!-- Email -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtemail"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập Email"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />

            <!-- Password -->

            <TextView
                android:id="@+id/textView4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mật khẩu"
                android:layout_marginBottom="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtpassword"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />

        <!-- Button -->
            <Button
                android:id="@+id/btnlogin"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/button_login"
                android:backgroundTint="@null"
                android:text="Đăng ký"
                android:textColor="#000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!--   Hoặc
              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="10dp"
                  android:layout_marginBottom="10dp"
                  android:text="Hoặc"
                  android:textColor="@color/mauchu"
                  android:textStyle="bold" /> -->

            <!-- Social

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:background="@drawable/img_5" />

                <ImageButton
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/img_6" />
            </LinearLayout>-->

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn chưa có tài khoản ?"
            android:textColor="@color/mauchu" />

        <TextView
            android:id="@+id/txtdk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text=" Đăng nhập"
            android:textColor="@color/mauchu" />
    </LinearLayout>
</LinearLayout>