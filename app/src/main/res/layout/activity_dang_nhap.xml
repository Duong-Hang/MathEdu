<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/maunen"
    tools:context=".Login.DangNhap">

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="128dp"
        app:srcCompat="@drawable/img_2" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:cardBackgroundColor="#84EEFF"
        app:cardCornerRadius="30dp"
        app:strokeColor="@color/mauvien"
        app:strokeWidth="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:background="@drawable/bg_rounded"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Title -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="ĐĂNG NHẬP"
                android:textAlignment="center"
                android:textColor="#004875"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Username
            <TextView
                android:id="@+id/textView2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Tên đăng nhập"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/txtten"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập tên đăng nhập"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />  -->

            <!-- Email -->
            <TextView
                android:id="@+id/textView3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Email/Tên đăng nhập"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtemail"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập Email/Tên đăng nhập"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />

            <!-- Password -->

            <TextView
                android:id="@+id/textView4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="Mật khẩu"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtpassword"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_edittext"
                android:hint="Nhập mật khẩu"
                android:inputType="textPassword"
                android:padding="5dp"
                android:textColorHint="#3867B3"
                android:textSize="12dp" />
            <!-- Vai trò -->

            <TextView
                android:id="@+id/textView7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vai trò"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp"
                android:textAlignment="center"
                android:textColor="#005CA0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Lựa chọn -->
            <RadioGroup
                android:id="@+id/rdgroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radph"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phụ huynh"
                    android:textColor="@color/mauchu"
                    android:layout_marginRight="15dp"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/radhs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Học sinh"
                    android:textColor="@color/mauchu"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </RadioGroup>

            <!--Quên mật khẩu-->
            <TextView
                android:id="@+id/txtquen"
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                android:text="Quên mật khẩu?"
                android:textColor="@color/mauchu"
                android:textStyle="bold" />
            <!-- Button -->
            <Button
                android:id="@+id/btnlogin"
                android:layout_width="180dp"
                android:layout_height="50dp"
                android:background="@drawable/button_login"
                android:backgroundTint="@null"
                android:text="Đăng nhập"
                android:textColor="#000"
                android:textSize="18sp"
                android:textStyle="bold" />


            <!-- Social

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:background="@drawable/img_5" />

                <ImageButton
                    android:layout_width="50dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/img_6" />
            </LinearLayout>-->

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn chưa có tài khoản ?"
            android:textColor="@color/mauchu" />

        <TextView
            android:id="@+id/txtdk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text=" Đăng ký"
            android:textColor="@color/mauchu" />

    </LinearLayout>

    <TextView
        android:id="@+id/textView6"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="*Lưu ý: phụ huynh bắt buộc phải đăng nhập bằng Email"
        android:textSize="12sp"/>

</LinearLayout>